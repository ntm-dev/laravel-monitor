{
    "name": "ntm-dev/laravel-monitor",
    "description": "Local-first application monitoring for Laravel — Nightwatch-style insights (requests, queries, jobs, exceptions, cache, mail, ...) on a self-hosted Livewire dashboard like Pulse.",
    "keywords": ["laravel", "monitoring", "pulse", "nightwatch", "telescope", "observability"],
    "homepage": "https://github.com/ntm-dev/laravel-monitor",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Manh Nguyen",
            "email": "hoangtupro.a4@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0|^4.0",
        "nesbot/carbon": "^2.67|^3.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.36|^9.15|^10.8|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "LaravelMonitor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "LaravelMonitor\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelMonitor\\MonitorServiceProvider"
            ],
            "aliases": {
                "Monitor": "LaravelMonitor\\Facades\\Monitor"
            }
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
